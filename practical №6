<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Форма</title>
</head>
<body>

<h2>Реєстрація / Вхід</h2>

<input id="name" placeholder="Ім'я"><br><br>
<input id="email" placeholder="Email"><br><br>
<input id="phone" placeholder="Телефон"><br><br>
<input id="password" type="password" placeholder="Пароль"><br><br>

<button onclick="saveUser()">Зберегти</button>
<button onclick="login()">Увійти</button>
<button onclick="clearData()">Очистити</button>

<p id="status"></p>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const user = JSON.parse(localStorage.getItem('user'));

  if (user) {
    document.getElementById('name').value = user.name;
    document.getElementById('email').value = user.email;
    document.getElementById('phone').value = user.phone;
  }
});

function saveUser() {
  const user = {
    name: document.getElementById('name').value,
    email: document.getElementById('email').value,
    phone: document.getElementById('phone').value,
    password: document.getElementById('password').value
  };

  if (!user.email || !user.password) {
    return alert('Email і пароль обовʼязкові');
  }

  localStorage.setItem('user', JSON.stringify(user));
  document.getElementById('status').textContent = 'Збережено!';
}

function login() {
  const stored = JSON.parse(localStorage.getItem('user'));
  const email = document.getElementById('email').value;
  const password = document.getElementById('password').value;

  if (stored && stored.email === email && stored.password === password) {
    document.getElementById('status').textContent = 'Успішний вхід';
  } else {
    document.getElementById('status').textContent = 'Помилка входу';
  }
}

function clearData() {
  localStorage.removeItem('user');
  location.reload();
}
</script>

</body>
</html>
