<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Відвідування</title>
</head>
<body>

<h2>Лічильник відвідувань</h2>
<p id="count"></p>

<button onclick="resetHistory()">Скинути</button>

<table border="1">
  <thead>
    <tr><th>#</th><th>Дата</th></tr>
  </thead>
  <tbody id="history"></tbody>
</table>

<script>
document.addEventListener('DOMContentLoaded', () => {
  let visits = JSON.parse(localStorage.getItem('visits')) || [];

  visits.push(new Date().toLocaleString());
  localStorage.setItem('visits', JSON.stringify(visits));

  document.getElementById('count').textContent = `Кількість відвідувань: ${visits.length}`;

  const table = document.getElementById('history');
  table.innerHTML = visits.map((v, i) => `<tr><td>${i+1}</td><td>${v}</td></tr>`).join('');
});

function resetHistory() {
  localStorage.removeItem('visits');
  location.reload();
}
</script>

</body>
</html>



