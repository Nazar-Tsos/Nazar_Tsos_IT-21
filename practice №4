//Варіант 1
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Список</title>
</head>
<body>

<input type="text" id="input" placeholder="Введіть текст">
<button id="addBtn">Додати</button>
<button id="sortBtn">Сортувати</button>

<ul id="list"></ul>

<script>
const input = document.getElementById("input");
const addBtn = document.getElementById("addBtn");
const sortBtn = document.getElementById("sortBtn");
const list = document.getElementById("list");

// Додавання елемента
addBtn.addEventListener("click", () => {
    const value = input.value.trim();

    if (!value) {
        alert("Введіть текст!");
        return;
    }

    const li = document.createElement("li");
    li.textContent = value;

    // Видалення при кліку
    li.addEventListener("click", () => {
        li.remove();
    });

    list.appendChild(li);
    input.value = "";
});

// Сортування
sortBtn.addEventListener("click", () => {
    const items = Array.from(list.children);

    items.sort((a, b) => a.textContent.localeCompare(b.textContent));

    list.innerHTML = "";
    items.forEach(item => list.appendChild(item));
});
</script>

</body>
</html>




//Варіант 2
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Стилі</title>
</head>
<body>

<div id="text">Це текст для змін</div>

<button id="color">Змінити колір</button>
<button id="font">Змінити шрифт</button>
<button id="bg">Змінити фон</button>
<button id="toggle">Сховати/показати</button>
<button id="reset">Скинути</button>

<script>
const text = document.getElementById("text");

document.getElementById("color").onclick = () => {
    text.style.color = "red";
};

document.getElementById("font").onclick = () => {
    text.style.fontSize = "24px";
};

document.getElementById("bg").onclick = () => {
    document.body.style.backgroundColor = "lightblue";
};

document.getElementById("toggle").onclick = () => {
    text.style.display = text.style.display === "none" ? "block" : "none";
};

document.getElementById("reset").onclick = () => {
    text.style = "";
    document.body.style = "";
};
</script>

</body>
</html>




