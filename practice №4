<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Таймер</title>
</head>
<body>

<input type="number" id="timeInput" placeholder="Секунди">
<div id="display">0</div>

<button id="start">Старт</button>
<button id="pause">Пауза</button>
<button id="add">+10 сек</button>
<button id="minus">-10 сек</button>

<script>
let time = 0;
let interval = null;

const display = document.getElementById("display");

// Оновлення дисплею
function updateDisplay() {
    display.textContent = time;
}

// Старт
document.getElementById("start").onclick = () => {
    const inputVal = parseInt(document.getElementById("timeInput").value);

    if (!interval) {
        if (!time && inputVal > 0) time = inputVal;

        interval = setInterval(() => {
            if (time > 0) {
                time--;
                updateDisplay();
            } else {
                clearInterval(interval);
                interval = null;
                alert("Час вийшов!");
            }
        }, 1000);
    }
};

// Пауза
document.getElementById("pause").onclick = () => {
    clearInterval(interval);
    interval = null;
};

// Додати час
document.getElementById("add").onclick = () => {
    time += 10;
    updateDisplay();
};

// Зменшити час
document.getElementById("minus").onclick = () => {
    time = Math.max(0, time - 10);
    updateDisplay();
};
</script>

</body>
</html>




